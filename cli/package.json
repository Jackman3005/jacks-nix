{
  "name": "jacks-nix-cli",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build:darwin-arm64": "bun build --compile --minify --target=bun-darwin-arm64 src/index.tsx --outfile ../jacks-nix-darwin-arm64",
    "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64 src/index.tsx --outfile ../jacks-nix-linux-x64",
    "build": "bun run build:darwin-arm64 && bun run build:linux-x64"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.7.0"
  }
}
